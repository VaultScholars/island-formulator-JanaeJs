<div class="space-y-8">
  <!-- Hero Welcome Section -->
  <div class="relative overflow-hidden bg-gradient-to-r from-emerald-600 to-teal-600 rounded-3xl shadow-2xl p-10 text-white">
    <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-32 -mt-32"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/10 rounded-full -ml-24 -mb-24"></div>
    <div class="relative z-10">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-5xl font-black mb-3">Welcome back, <%= Current.user.email_address.split('@').first.capitalize %>! 👋</h1>
          <p class="text-emerald-100 text-xl font-light"><%= Time.now.strftime("%A, %B %d, %Y") %></p>
        </div>
        <div class="hidden md:block">
          <div class="w-24 h-24 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center">
            <span class="text-6xl">🌿</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Grid - Enhanced with gradients and icons -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Ingredients Card -->
    <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-emerald-200">
      <div class="h-2 bg-gradient-to-r from-emerald-400 to-emerald-600"></div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-3xl">🌱</span>
          </div>
          <div class="text-right">
            <p class="text-5xl font-black text-emerald-600"><%= @stats[:ingredients] %></p>
          </div>
        </div>
        <p class="text-gray-500 uppercase text-xs font-bold tracking-wider mb-3">Ingredients</p>
        <%= link_to "View all →", ingredients_path, class: "text-emerald-600 font-semibold text-sm hover:text-emerald-700 inline-flex items-center gap-1 group-hover:gap-2 transition-all" %>
      </div>
    </div>

    <!-- Recipes Card -->
    <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-teal-200">
      <div class="h-2 bg-gradient-to-r from-teal-400 to-teal-600"></div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-3xl">📖</span>
          </div>
          <div class="text-right">
            <p class="text-5xl font-black text-teal-600"><%= @stats[:recipes] %></p>
          </div>
        </div>
        <p class="text-gray-500 uppercase text-xs font-bold tracking-wider mb-3">Recipes</p>
        <%= link_to "View all →", recipes_path, class: "text-teal-600 font-semibold text-sm hover:text-teal-700 inline-flex items-center gap-1 group-hover:gap-2 transition-all" %>
      </div>
    </div>

    <!-- Inventory Card -->
    <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-amber-200">
      <div class="h-2 bg-gradient-to-r from-amber-400 to-amber-600"></div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-3xl">📦</span>
          </div>
          <div class="text-right">
            <p class="text-5xl font-black text-amber-600"><%= @stats[:inventory] %></p>
          </div>
        </div>
        <p class="text-gray-500 uppercase text-xs font-bold tracking-wider mb-3">Inventory Items</p>
        <%= link_to "View all →", inventory_items_path, class: "text-amber-600 font-semibold text-sm hover:text-amber-700 inline-flex items-center gap-1 group-hover:gap-2 transition-all" %>
      </div>
    </div>

    <!-- Batches Card -->
    <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-purple-200">
      <div class="h-2 bg-gradient-to-r from-purple-400 to-purple-600"></div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-3xl">✨</span>
          </div>
          <div class="text-right">
            <p class="text-5xl font-black text-purple-600"><%= @stats[:batches] %></p>
          </div>
        </div>
        <p class="text-gray-500 uppercase text-xs font-bold tracking-wider mb-3">Total Batches</p>
        <%= link_to "View all →", batches_path, class: "text-purple-600 font-semibold text-sm hover:text-purple-700 inline-flex items-center gap-1 group-hover:gap-2 transition-all" %>
      </div>
    </div>
  </div>

  <!-- Recent Activity Section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Recent Recipes -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-emerald-500 to-teal-500 px-6 py-4 flex justify-between items-center">
        <h2 class="font-black text-2xl text-white flex items-center gap-2">
          <span>📖</span> Recent Recipes
        </h2>
        <%= link_to new_recipe_path, class: "px-4 py-2 bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white font-bold rounded-full transition-all" do %>
          + New
        <% end %>
      </div>
      <div class="divide-y divide-gray-100">
        <% if @recent_recipes.any? %>
          <% @recent_recipes.each do |recipe| %>
            <div class="p-5 hover:bg-emerald-50 transition-colors group">
              <div class="flex justify-between items-start">
                <div class="flex-1">
                  <%= link_to recipe.title, recipe, class: "text-lg font-bold text-gray-800 hover:text-emerald-600 transition-colors mb-1 block" %>
                  <p class="text-sm text-gray-500 flex items-center gap-2">
                    <span class="px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-semibold"><%= recipe.product_type %></span>
                    <span class="text-gray-400">•</span>
                    <span><%= pluralize(recipe.ingredients.count, 'ingredient') %></span>
                  </p>
                </div>
                <span class="text-sm text-gray-400 font-medium"><%= recipe.created_at.strftime("%b %d") %></span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-12 text-center">
            <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">📖</span>
            </div>
            <p class="text-gray-500 mb-4 font-medium">No recipes yet.</p>
            <%= link_to "Create your first recipe", new_recipe_path, class: "inline-block px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-full hover:shadow-lg transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Batches -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-purple-500 to-pink-500 px-6 py-4 flex justify-between items-center">
        <h2 class="font-black text-2xl text-white flex items-center gap-2">
          <span>✨</span> Recent Batches
        </h2>
        <%= link_to new_batch_path, class: "px-4 py-2 bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white font-bold rounded-full transition-all" do %>
          + Log
        <% end %>
      </div>
      <div class="divide-y divide-gray-100">
        <% if @recent_batches.any? %>
          <% @recent_batches.each do |batch| %>
            <div class="p-5 hover:bg-purple-50 transition-colors">
              <div class="flex justify-between items-start mb-2">
                <p class="font-bold text-gray-800"><%= batch.recipe.title %></p>
                <div class="text-right">
                  <span class="block text-sm text-gray-500 font-medium"><%= batch.made_on.strftime("%b %d") %></span>
                  <%= link_to "Details", batch, class: "text-xs text-purple-600 hover:text-purple-700 font-semibold" %>
                </div>
              </div>
              <% if batch.notes.present? %>
                <p class="text-sm text-gray-600 italic line-clamp-2">"<%= batch.notes.truncate(60) %>"</p>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="p-12 text-center">
            <div class="w-20 h-20 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">✨</span>
            </div>
            <p class="text-gray-500 mb-4 font-medium">No batches logged yet.</p>
            <%= link_to "Log your first batch", new_batch_path, class: "inline-block px-6 py-3 bg-gradient-to-r from-purple-500 to-pink-500 text-white font-bold rounded-full hover:shadow-lg transition-all" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Actions - Beautiful Cards -->
  <div class="bg-gradient-to-br from-white to-emerald-50 rounded-3xl shadow-xl p-10 border-2 border-emerald-100">
    <h2 class="font-black text-3xl text-center mb-8 bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">⚡ Quick Actions</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <%= link_to new_ingredient_path, class: "group bg-white hover:bg-gradient-to-br hover:from-emerald-500 hover:to-teal-600 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-emerald-200 hover:border-transparent text-center" do %>
        <div class="text-5xl mb-3">🌱</div>
        <p class="font-bold text-gray-800 group-hover:text-white transition-colors">Add Ingredient</p>
      <% end %>
      
      <%= link_to new_inventory_item_path, class: "group bg-white hover:bg-gradient-to-br hover:from-amber-500 hover:to-orange-600 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-amber-200 hover:border-transparent text-center" do %>
        <div class="text-5xl mb-3">📦</div>
        <p class="font-bold text-gray-800 group-hover:text-white transition-colors">Record Purchase</p>
      <% end %>
      
      <%= link_to new_recipe_path, class: "group bg-white hover:bg-gradient-to-br hover:from-teal-500 hover:to-cyan-600 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-teal-200 hover:border-transparent text-center" do %>
        <div class="text-5xl mb-3">📖</div>
        <p class="font-bold text-gray-800 group-hover:text-white transition-colors">Create Recipe</p>
      <% end %>
      
      <%= link_to new_batch_path, class: "group bg-white hover:bg-gradient-to-br hover:from-purple-500 hover:to-pink-600 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-purple-200 hover:border-transparent text-center" do %>
        <div class="text-5xl mb-3">✨</div>
        <p class="font-bold text-gray-800 group-hover:text-white transition-colors">Log Production</p>
      <% end %>
    </div>
  </div>
</div>