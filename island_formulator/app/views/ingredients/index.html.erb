<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-5xl font-black bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent mb-2">My Ingredients 🌿</h1>
      <p class="text-gray-600 text-lg">Your formulation pantry</p>
    </div>
    <%= link_to new_ingredient_path, class: "group px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105 flex items-center gap-2" do %>
      <span class="text-2xl">+</span>
      <span>Add Ingredient</span>
    <% end %>
  </div>

  <% if @ingredients.empty? %>
    <!-- Empty State -->
    <div class="bg-gradient-to-br from-white to-emerald-50 rounded-3xl shadow-xl p-16 text-center border-2 border-dashed border-emerald-200">
      <div class="w-32 h-32 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-7xl">🌱</span>
      </div>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">No ingredients yet</h2>
      <p class="text-gray-600 mb-8 text-lg">Start building your ingredient library!</p>
      <%= link_to "Add Your First Ingredient", new_ingredient_path, class: "inline-block px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105" %>
    </div>
  <% else %>
    <!-- Ingredients Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @ingredients.each do |ingredient| %>
        <%= link_to ingredient, class: "group" do %>
          <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-emerald-200 h-full">
            <!-- Category Badge at top -->
            <div class="h-2 bg-gradient-to-r from-emerald-400 to-teal-500"></div>
            
            <div class="p-6">
              <!-- Category Badge -->
              <div class="mb-4">
                <span class="inline-block px-4 py-1.5 text-xs font-black tracking-wider uppercase bg-emerald-100 text-emerald-800 rounded-full">
                  <%= ingredient.category %>
                </span>
              </div>
              
              <!-- Name -->
              <h2 class="text-2xl font-black text-gray-800 mb-3 group-hover:text-emerald-600 transition-colors">
                <%= ingredient.name %>
              </h2>
              
              <!-- Description -->
              <% if ingredient.description.present? %>
                <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                  <%= ingredient.description %>
                </p>
              <% end %>
              
              <!-- Tags -->
              <% if ingredient.tags.any? %>
                <div class="flex flex-wrap gap-2 mb-4">
                  <% ingredient.tags.first(3).each do |tag| %>
                    <span class="inline-block px-3 py-1 bg-teal-50 text-teal-700 text-xs font-semibold rounded-full border border-teal-200">
                      <%= tag.name %>
                    </span>
                  <% end %>
                  <% if ingredient.tags.count > 3 %>
                    <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full">
                      +<%= ingredient.tags.count - 3 %> more
                    </span>
                  <% end %>
                </div>
              <% end %>
              
              <!-- View Link -->
              <div class="pt-4 border-t border-gray-100">
                <span class="text-emerald-600 font-bold text-sm group-hover:text-emerald-700 inline-flex items-center gap-2">
                  View Details
                  <span class="group-hover:translate-x-1 transition-transform">→</span>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>