<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Island Formulator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Island Formulator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gradient-to-br from-emerald-50 via-white to-teal-50 min-h-screen">
    <!-- Enhanced Navigation with gradient -->
    <nav class="bg-white/90 backdrop-blur-md shadow-lg sticky top-0 z-50 border-b-2 border-emerald-100">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <!-- Left side - Branding & Navigation -->
          <div class="flex items-center gap-8">
            <%= link_to root_path, class: "flex items-center gap-3 group" do %>
              <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <span class="text-white font-black text-xl">IF</span>
              </div>
              <span class="text-2xl font-black bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
                Island Formulator
              </span>
            <% end %>
            
           <% if authenticated? %>
  <div class="hidden md:flex items-center gap-6 ml-8">
    <%= link_to "Dashboard", root_path, class: "text-gray-700 hover:text-emerald-600 font-semibold transition-colors relative group" %>
    <%= link_to "Recipes", recipes_path, class: "text-gray-700 hover:text-emerald-600 font-semibold transition-colors relative group" %>
    <%= link_to "Favorites", favorites_path, class: "text-pink-600 hover:text-pink-700 font-semibold transition-colors relative group" %>
    <%= link_to "Inventory", inventory_items_path, class: "text-gray-700 hover:text-emerald-600 font-semibold transition-colors relative group" %>
    <%= link_to "Batches", batches_path, class: "text-gray-700 hover:text-emerald-600 font-semibold transition-colors relative group" %>
    <%= link_to "Ingredients", ingredients_path, class: "text-gray-700 hover:text-emerald-600 font-semibold transition-colors relative group" %>
  </div>
<% end %>
          </div>
          
          <!-- Right side - User menu -->
          <div class="flex items-center gap-4">
            <% if authenticated? %>
              <div class="flex items-center gap-3 bg-emerald-50 px-4 py-2 rounded-full">
                <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-full flex items-center justify-center">
                  <span class="text-white text-sm font-bold"><%= Current.user.email_address[0].upcase %></span>
                </div>
                <span class="text-sm font-medium text-gray-700"><%= Current.user.email_address.split('@').first %></span>
              </div>
              <%= button_to "Logout", session_path, method: :delete, class: "px-5 py-2 bg-red-50 text-red-600 hover:bg-red-100 rounded-full font-semibold transition-all hover:shadow-md" %>
            <% else %>
              <%= link_to "Sign Up", new_user_path, class: "px-6 py-2.5 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-full hover:shadow-xl transition-all hover:scale-105" %>
              <%= link_to "Login", new_session_path, class: "px-6 py-2.5 bg-white border-2 border-emerald-500 text-emerald-600 font-bold rounded-full hover:bg-emerald-50 transition-all" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content Area -->
    <main class="container mx-auto px-6 py-8 max-w-7xl">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="mt-16 bg-gradient-to-r from-emerald-900 to-teal-900 text-white py-8">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <p class="text-emerald-100">© <%= Time.now.year %> Island Formulator - Crafted with 💚</p>
      </div>
    </footer>
  </body>
</html>