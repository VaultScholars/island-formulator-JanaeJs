<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-5xl font-black bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent mb-2">Inventory 📦</h1>
      <p class="text-gray-600 text-lg">Track your purchases and stock</p>
    </div>
    <%= link_to new_inventory_item_path, class: "group px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105 flex items-center gap-2" do %>
      <span class="text-2xl">+</span>
      <span>New Item</span>
    <% end %>
  </div>

  <% if @inventory_items.empty? %>
    <!-- Empty State -->
    <div class="bg-gradient-to-br from-white to-amber-50 rounded-3xl shadow-xl p-16 text-center border-2 border-dashed border-amber-200">
      <div class="w-32 h-32 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-7xl">📦</span>
      </div>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">No inventory items yet</h2>
      <p class="text-gray-600 mb-8 text-lg">Start tracking your purchases!</p>
      <%= link_to "Add Your First Item", new_inventory_item_path, class: "inline-block px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105" %>
    </div>
  <% else %>
    <!-- Inventory Table -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border-2 border-amber-100">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="bg-gradient-to-r from-amber-500 to-orange-500 text-white">
              <th class="px-6 py-4 text-left text-sm font-black uppercase tracking-wider">Ingredient</th>
              <th class="px-6 py-4 text-left text-sm font-black uppercase tracking-wider">Brand</th>
              <th class="px-6 py-4 text-left text-sm font-black uppercase tracking-wider">Size</th>
              <th class="px-6 py-4 text-left text-sm font-black uppercase tracking-wider">Location</th>
              <th class="px-6 py-4 text-left text-sm font-black uppercase tracking-wider">Purchased</th>
              <th class="px-6 py-4 text-right text-sm font-black uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @inventory_items.each do |item| %>
              <tr class="hover:bg-amber-50 transition-colors">
                <td class="px-6 py-5">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center">
                      <span class="text-xl">🌿</span>
                    </div>
                    <span class="font-bold text-gray-900"><%= item.ingredient.name %></span>
                  </div>
                </td>
                <td class="px-6 py-5 text-gray-700 font-medium"><%= item.brand %></td>
                <td class="px-6 py-5 text-gray-700"><%= item.size %></td>
                <td class="px-6 py-5 text-gray-700"><%= item.location %></td>
                <td class="px-6 py-5 text-gray-600"><%= item.purchase_date.strftime("%b %d, %Y") %></td>
                <td class="px-6 py-5 text-right">
                  <div class="flex justify-end gap-3">
                    <%= link_to "View", item, class: "text-amber-600 hover:text-amber-700 font-bold text-sm" %>
                    <%= link_to "Edit", edit_inventory_item_path(item), class: "text-gray-600 hover:text-gray-700 font-bold text-sm" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>