<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-5xl font-black bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent mb-2">My Recipes 📖</h1>
      <p class="text-gray-600 text-lg">Your formulation cookbook</p>
    </div>
    <%= link_to new_recipe_path, class: "group px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105 flex items-center gap-2" do %>
      <span class="text-2xl">+</span>
      <span>New Recipe</span>
    <% end %>
  </div>

  <% if @recipes.empty? %>
    <!-- Empty State -->
    <div class="bg-gradient-to-br from-white to-emerald-50 rounded-3xl shadow-xl p-16 text-center border-2 border-dashed border-emerald-200">
      <div class="w-32 h-32 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-7xl">📖</span>
      </div>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">No recipes yet</h2>
      <p class="text-gray-600 mb-8 text-lg">Start building your formulation library!</p>
      <%= link_to "Create Your First Recipe", new_recipe_path, class: "inline-block px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105" %>
    </div>
  <% else %>
    <!-- Recipe Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @recipes.each do |recipe| %>
        <%= link_to recipe, class: "group" do %>
          <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-2 border-transparent hover:border-emerald-200 h-full flex flex-col">
            <!-- Recipe Image -->
            <div class="relative h-56 bg-gradient-to-br from-emerald-100 to-teal-100 overflow-hidden">
              <% if recipe.photo.attached? %>
                <%= image_tag recipe.photo, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" %>
              <% else %>
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="text-8xl opacity-30">📖</span>
                </div>
              <% end %>
              <!-- Floating Badge -->
              <div class="absolute top-4 right-4">
                <span class="px-4 py-2 bg-white/90 backdrop-blur-sm text-emerald-700 text-xs font-black uppercase tracking-wider rounded-full shadow-lg">
                  <%= recipe.product_type %>
                </span>
              </div>
            </div>
            
            <!-- Recipe Info -->
            <div class="p-6 flex-1 flex flex-col">
              <h2 class="text-2xl font-black text-gray-800 mb-3 group-hover:text-emerald-600 transition-colors">
                <%= recipe.title %>
              </h2>
              
              <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                <span class="flex items-center gap-1">
                  <span class="text-lg">🌿</span>
                  <%= pluralize(recipe.ingredients.count, 'ingredient') %>
                </span>
                <span class="flex items-center gap-1">
                  <span class="text-lg">📅</span>
                  <%= recipe.created_at.strftime("%b %d") %>
                </span>
              </div>
              
              <% if recipe.method.present? %>
                <p class="text-gray-600 text-sm line-clamp-2 mb-4">
                  <%= recipe.method.truncate(100) %>
                </p>
              <% end %>
              
              <!-- View Button -->
              <div class="mt-auto pt-4 border-t border-gray-100">
                <span class="text-emerald-600 font-bold text-sm group-hover:text-emerald-700 inline-flex items-center gap-2">
                  View Recipe
                  <span class="group-hover:translate-x-1 transition-transform">→</span>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>