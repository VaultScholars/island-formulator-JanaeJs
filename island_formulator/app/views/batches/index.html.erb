<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-5xl font-black bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-2">Batch History ✨</h1>
      <p class="text-gray-600 text-lg">Your production log</p>
    </div>
    <%= link_to new_batch_path, class: "group px-8 py-4 bg-gradient-to-r from-purple-500 to-pink-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105 flex items-center gap-2" do %>
      <span class="text-2xl">+</span>
      <span>Log Batch</span>
    <% end %>
  </div>

  <% if @batches.empty? %>
    <!-- Empty State -->
    <div class="bg-gradient-to-br from-white to-purple-50 rounded-3xl shadow-xl p-16 text-center border-2 border-dashed border-purple-200">
      <div class="w-32 h-32 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-7xl">✨</span>
      </div>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">No batches logged yet</h2>
      <p class="text-gray-600 mb-8 text-lg">Start tracking your production!</p>
      <%= link_to "Log Your First Batch", new_batch_path, class: "inline-block px-8 py-4 bg-gradient-to-r from-purple-500 to-pink-600 text-white font-bold rounded-2xl hover:shadow-2xl transition-all hover:scale-105" %>
    </div>
  <% else %>
    <!-- Batch Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @batches.each do |batch| %>
        <%= link_to batch, class: "group" do %>
          <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border-l-8 border-purple-500 hover:border-pink-500">
            <div class="p-6">
              <!-- Date Badge -->
              <div class="flex justify-between items-start mb-4">
                <span class="px-4 py-2 bg-purple-100 text-purple-700 text-xs font-black uppercase tracking-wider rounded-full">
                  <%= batch.made_on.strftime("%b %d, %Y") %>
                </span>
                <span class="text-2xl">✨</span>
              </div>
              
              <!-- Recipe Title -->
              <h2 class="text-2xl font-black text-gray-800 mb-3 group-hover:text-purple-600 transition-colors">
                <%= batch.recipe.title %>
              </h2>
              
              <!-- Recipe Type -->
              <p class="text-sm text-gray-500 mb-4 font-medium">
                <%= batch.recipe.product_type %>
              </p>
              
              <!-- Notes Preview -->
              <% if batch.notes.present? %>
                <div class="bg-purple-50 rounded-xl p-4 mb-4">
                  <p class="text-sm text-gray-700 italic line-clamp-2">
                    "<%= batch.notes.truncate(80) %>"
                  </p>
                </div>
              <% end %>
              
              <!-- View Link -->
              <div class="pt-4 border-t border-gray-100">
                <span class="text-purple-600 font-bold text-sm group-hover:text-purple-700 inline-flex items-center gap-2">
                  View Details
                  <span class="group-hover:translate-x-1 transition-transform">→</span>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>